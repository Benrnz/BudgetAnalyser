<Window x:Class="BudgetAnalyser.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:budgetAnalyser="clr-namespace:BudgetAnalyser"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shellDialog="clr-namespace:BudgetAnalyser.ShellDialog"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Background="{StaticResource Brush.MainBackground}"
        SizeChanged="OnSizeChanged"
        LocationChanged="OnLocationChanged"
        Icon="UI/Assets/PieChart.png"
        Loaded="OnLoaded"
        MinHeight="600"
        MinWidth="800"
        SizeToContent="Manual"
        SnapsToDevicePixels="True"
        Title="{Binding WindowTitle}"
        Closing="ShellWindow_OnClosing"
        d:DataContext="{d:DesignInstance budgetAnalyser:ShellController}">

    <Window.InputBindings>
        <KeyBinding Key="S"
                    Command="{x:Static budgetAnalyser:PersistenceOperationCommands.SaveDatabaseCommand}"
                    Modifiers="Control" />
    </Window.InputBindings>

    <DockPanel>
        <!-- Tab Bar Menu Control -->
        <Grid DockPanel.Dock="Top">
            <budgetAnalyser:MainMenuUserControl DataContext="{Binding MainMenuController}" />
        </Grid>

        <!-- Main Content Area -->
        <Grid>
            <Grid Visibility="{Binding TopTransactionsController.Shown, Converter={StaticResource Converter.BoolToVis}}">
                <ContentPresenter Content="{Binding TopTransactionsController}" />
                <shellDialog:ShellDialogView DataContext="{Binding TransactionsTabDialog}" />
            </Grid>

            <Grid Visibility="{Binding TopBudgetController.Shown, Converter={StaticResource Converter.BoolToVis}}">
                <ContentPresenter Content="{Binding TopBudgetController}"
                                  VerticalAlignment="Stretch" />
                <shellDialog:ShellDialogView DataContext="{Binding BudgetTabDialog}" />
            </Grid>

            <Grid Visibility="{Binding TopLedgerBookController.Shown, Converter={StaticResource Converter.BoolToVis}}">
                <ContentPresenter Content="{Binding TopLedgerBookController}"
                                  VerticalAlignment="Stretch" />
                <shellDialog:ShellDialogView DataContext="{Binding LedgerBookTabDialog}" />
            </Grid>

            <Grid Visibility="{Binding TopDashboardController.Shown, Converter={StaticResource Converter.BoolToVis}}">
                <ContentPresenter Content="{Binding TopDashboardController}"
                                  VerticalAlignment="Stretch" />
                <shellDialog:ShellDialogView DataContext="{Binding DashboardTabDialog}" />
            </Grid>

            <Grid Visibility="{Binding TopReportsCatalogController.Shown, Converter={StaticResource Converter.BoolToVis}}">
                <ContentPresenter Content="{Binding TopReportsCatalogController}"
                                  VerticalAlignment="Stretch" />
                <shellDialog:ShellDialogView DataContext="{Binding ReportsTabDialog}" />
            </Grid>
        </Grid>
    </DockPanel>

</Window>
