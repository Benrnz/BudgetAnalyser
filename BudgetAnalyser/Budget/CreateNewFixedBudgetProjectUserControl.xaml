<UserControl x:Class="BudgetAnalyser.Budget.CreateNewFixedBudgetProjectUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:budget="clr-namespace:BudgetAnalyser.Budget"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance budget:CreateNewFixedBudgetController}"
             Background="{StaticResource Brush.DialogBackground}" >

    <Grid FocusManager.FocusedElement="{Binding ElementName=CodeTextBox}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Column="0"
                    Grid.Row="1">
            <TextBlock Style="{StaticResource TextBlock.LabelStyle}"
                       Text="Code" />
            <TextBox x:Name="CodeTextBox"
                     Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Grid.Row="1">
            <TextBlock Style="{StaticResource TextBlock.LabelStyle}"
                       Text="Amount" />
            <TextBox Text="{Binding Amount, StringFormat=C, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
        <StackPanel Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Grid.Row="2">
            <TextBlock Style="{StaticResource TextBlock.LabelStyle}"
                       Text="Description" />
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
    </Grid>

</UserControl>
